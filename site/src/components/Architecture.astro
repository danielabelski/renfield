---
const flowSteps = ['User Input', 'Intent Recognition', 'Agent / Action', 'MCP Tools', 'Response'];
---

<section class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="reveal">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-center text-gray-900 dark:text-white mb-4">
        Architecture
      </h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto">
        Modular design with MCP protocol for tool integration, local LLM inference via Ollama,
        and a React PWA frontend.
      </p>
    </div>

    <div class="reveal max-w-4xl mx-auto rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700">
      <img
        src="/architecture.svg"
        alt="Renfield Architecture Diagram"
        class="w-full hidden dark:block"
        loading="lazy"
      />
      <img
        src="/architecture-light.svg"
        alt="Renfield Architecture Diagram"
        class="w-full block dark:hidden"
        loading="lazy"
      />
    </div>

    <!-- Request flow summary with staggered reveal -->
    <div class="mt-10 max-w-3xl mx-auto">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-0 text-sm reveal-stagger flex-wrap">
        {flowSteps.map((step, i) => (
          <>
            <span class="reveal px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-700">
              {step}
            </span>
            {i < flowSteps.length - 1 && (
              <span class="reveal text-brand-cyan mx-1 hidden sm:inline">&rarr;</span>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</section>
