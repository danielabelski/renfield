---
const steps = [
  {
    num: '1',
    title: 'Clone & configure',
    code: `git clone https://github.com/ebongard/renfield.git\ncd renfield\ncp .env.example .env    # edit to your needs`,
  },
  {
    num: '2',
    title: 'Start the stack',
    code: 'docker compose up -d',
  },
  {
    num: '3',
    title: 'Pull a model',
    code: 'docker exec -it renfield-ollama ollama pull qwen3:8b',
    hint: true,
  },
];
---

<section id="quickstart" class="py-20 sm:py-28">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="reveal">
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-center text-gray-900 dark:text-white mb-4">
        Quick Start
      </h2>
      <p class="text-center text-gray-600 dark:text-gray-400 mb-12 max-w-xl mx-auto">
        Up and running in three steps. No cloud account required.
      </p>
    </div>

    <!-- Steps with connecting line -->
    <div class="reveal relative space-y-8">
      <div class="absolute left-5 top-10 bottom-10 w-px bg-gradient-to-b from-brand-red/50 via-brand-red/20 to-transparent hidden sm:block"></div>

      {steps.map((step) => (
        <div class="flex gap-4">
          <div class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-brand-red text-white flex items-center justify-center font-bold text-lg">
            {step.num}
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{step.title}</h3>
            <div class="relative group">
              <pre class="overflow-x-auto rounded-lg bg-gray-900 dark:bg-gray-800 text-gray-100 text-sm p-4 leading-relaxed"><code>{step.code}</code></pre>
              <button
                data-copy
                class="absolute top-2 right-2 p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 text-gray-400 hover:text-white transition-colors opacity-0 group-hover:opacity-100"
                title="Copy"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              </button>
            </div>
            {step.hint && (
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
                Open <code class="text-brand-cyan">http://localhost:3000</code> and start chatting.
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-copy]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var code = this.closest('.relative').querySelector('code').textContent;
      navigator.clipboard.writeText(code);
      var svg = this.querySelector('svg');
      var orig = svg.innerHTML;
      svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
      var self = this;
      setTimeout(function() { svg.innerHTML = orig; }, 1500);
    });
  });
</script>
