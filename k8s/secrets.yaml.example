# secrets.yaml.example — template for renfield-secrets
#
# DO NOT commit real values. Copy to secrets.yaml (git-ignored) and fill in.
# Encode each value: echo -n 'value' | base64
#
# Or apply imperatively via kubectl (preferred):
#   kubectl -n renfield create secret generic renfield-secrets \
#     --from-literal=postgres-password="$(pass postgres)" \
#     --from-literal=secret-key="$(openssl rand -hex 32)" \
#     ...
---
apiVersion: v1
kind: Secret
metadata:
  name: renfield-secrets
  namespace: renfield
  labels:
    app.kubernetes.io/part-of: renfield
type: Opaque
stringData:
  postgres-password: "CHANGEME"
  secret-key: "CHANGEME"            # openssl rand -hex 32
  default-admin-password: "CHANGEME"
  home-assistant-token: "CHANGEME"
  openweather-api-key: ""
  newsapi-key: ""
  jellyfin-api-key: ""
  jellyfin-token: ""
  jellyfin-base-url: ""
  jellyfin-user-id: ""
  n8n-api-key: ""
  paperless-api-token: ""
  mail-regfish-password: ""

---
# Pull secret for Harbor (registry.treehouse.x-idra.de)
# Apply imperatively from an already-logged-in docker config:
#   kubectl -n renfield create secret docker-registry harbor-pull-secret \
#     --docker-server=registry.treehouse.x-idra.de \
#     --docker-username=admin \
#     --docker-password='...' \
#     --docker-email=admin@x-idra.de
apiVersion: v1
kind: Secret
metadata:
  name: harbor-pull-secret
  namespace: renfield
  labels:
    app.kubernetes.io/part-of: renfield
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: CHANGEME_BASE64_DOCKER_CONFIG
